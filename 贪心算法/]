/* 376. 摆动序列
 * 难度：中等
 */

#include <cstdint>
#include <vector>
#include <iostream>

using namespace std;

class Solution {
public:
    int wiggleMaxLength(vector<int>& nums) {
        uint32_t slopes = 0;

        if(nums.size() < 2) return static_cast<int>(nums.size());
        if(nums.size() == 2) {
            if(nums[0] == nums[1]) return 1;
            else return 2;
        }

        int diff;
        int temp = 0;
        int t = 1;

        while(t < nums.size()) {
            if(nums[t] == nums[t-1]) t++;
        }
        diff = nums[t] - nums[t-1];
        if(!diff) return 1;

        for(size_t i = 2; i < nums.size(); ++i) {
            temp = nums[i] - nums[i-1];
            if (temp * diff < 0) {
                slopes += 1;
            }
            else if(!temp * diff) continue;
            diff = temp;
        }

        return slopes+1;
    }
};

int main(void)
{
    auto solu = Solution();
    //vector<int> nums{1,17,5,10,13,15,10,5,16,8};
    vector<int> nums{0, 0, 0};
    std::cout << solu.wiggleMaxLength(nums) << std::endl; 
}
